  "strings": {
    "“%@” will be permanently removed from your device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%@“ wird endgültig von Ihrem Gerät entfernt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "“%@” will be permanently removed from your device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» se eliminará permanentemente de tu dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "« %@ » sera définitivement supprimé de votre appareil."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "«%@» будет окончательно удалён с устройства."
