    "If videos stop loading, tap this to wipe stored cookies and the visitor token. The next playback attempt will run anonymously.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Videos nicht mehr geladen werden, hier tippen, um die gespeicherten Cookies und das Besucher-Token zu löschen. Der nächste Wiedergabeversuch erfolgt anonym."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If videos stop loading, tap this to wipe stored cookies and the visitor token. The next playback attempt will run anonymously."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si los vídeos dejan de cargar, toca para borrar las cookies guardadas y el token de visitante. El próximo intento de reproducción será anónimo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si les vidéos cessent de se charger, appuyez ici pour supprimer les cookies stockés et le jeton de visiteur. La prochaine tentative de lecture s’exécutera anonymement."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если видео перестали загружаться, нажмите, чтобы удалить сохранённые cookies и токен посетителя. Следующее воспроизведение начнётся анонимно."
          }
        }
      }
    },
