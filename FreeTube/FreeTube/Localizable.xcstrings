    "Videos download to your device before playback. Lower qualities save space and download faster.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Videos werden vor der Wiedergabe auf dein Gerät geladen. Niedrigere Qualitäten sparen Speicherplatz und laden schneller."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Videos download to your device before playback. Lower qualities save space and download faster."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los vídeos se descargan al dispositivo antes de reproducirse. Las calidades más bajas ahorran espacio y descargan más rápido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les vidéos se téléchargent sur votre appareil avant la lecture. Les qualités inférieures économisent de l’espace et se téléchargent plus rapidement."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Видео загружаются на устройство перед воспроизведением. Более низкое качество экономит место и загружается быстрее."
          }
        }
